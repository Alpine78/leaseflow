direction: right

internet: Internet {
  landlord_user: Landlord user
}

aws: AWS account {
  public_edge: Public edge {
    cloudfront: CloudFront frontend
    frontend_bucket: Private S3 SPA bucket
    api_gateway: API Gateway HTTP API
    routes_note: MVP routes
    route_scope: properties, leases, reminders, notifications
  }

  identity: Identity {
    cognito: Cognito User Pool
    app_client: App client
    claims_note: JWT: sub + custom:tenant_id
  }

  operations: Operations {
    cloudwatch_logs: CloudWatch Logs
    cloudwatch_alarms: CloudWatch Alarms
    sns_topic: SNS alarm topic
    eventbridge: EventBridge Scheduler
  }

  secrets: Secrets {
    ssm: SSM SecureString
  }

  vpc: Private VPC {
    private_subnets: Private subnets (2 AZs)
    lambda_backend: Lambda backend
    tenant_note: App-level tenant isolation

    rds_postgres: RDS PostgreSQL (private) {
      properties_table: properties
      leases_table: leases
      notifications_table: notifications
      audit_logs_table: audit_logs
    }
  }
}

internet.landlord_user -> aws.identity.cognito: Sign in
aws.identity.cognito -> internet.landlord_user: ID token
internet.landlord_user -> aws.public_edge.cloudfront: Load SPA
aws.public_edge.cloudfront -> aws.public_edge.frontend_bucket: Signed OAC origin access
internet.landlord_user -> aws.public_edge.api_gateway: HTTPS API calls
aws.public_edge.api_gateway -> aws.identity.cognito: JWT authorizer
aws.public_edge.api_gateway -> aws.vpc.lambda_backend: Lambda proxy invoke

aws.vpc.lambda_backend -> aws.vpc.tenant_note: Extract tenant_id from JWT
aws.vpc.lambda_backend -> aws.vpc.rds_postgres.properties_table: Tenant-scoped property CRUD
aws.vpc.lambda_backend -> aws.vpc.rds_postgres.leases_table: Tenant-scoped lease CRUD
aws.vpc.lambda_backend -> aws.vpc.rds_postgres.notifications_table: Persist/read reminders
aws.vpc.lambda_backend -> aws.vpc.rds_postgres.audit_logs_table: Audit write flows

aws.vpc.lambda_backend -> aws.secrets.ssm: Read DB password privately

aws.operations.eventbridge -> aws.vpc.lambda_backend: Daily reminder scan event
aws.vpc.lambda_backend -> aws.operations.cloudwatch_logs: Structured JSON logs
aws.operations.cloudwatch_alarms -> aws.operations.sns_topic: Alarm state action
aws.operations.cloudwatch_alarms -> aws.vpc.lambda_backend: Lambda errors/throttles
aws.operations.cloudwatch_alarms -> aws.public_edge.api_gateway: HTTP API 5xx
aws.operations.cloudwatch_alarms -> aws.operations.eventbridge: Scheduler target errors
